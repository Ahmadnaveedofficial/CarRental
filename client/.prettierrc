{
  "semi": true,                
  "singleQuote": true,         
  "trailingComma": "all",       
  "tabWidth": 2,                
  "useTabs": false,              
  "bracketSpacing": true,       
  "jsxBracketSameLine": false, 
  "arrowParens": "always",      
  "printWidth": 100,             
  "endOfLine": "lf"    
  
}

